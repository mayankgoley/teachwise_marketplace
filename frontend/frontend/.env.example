# ── TeachWise Frontend Environment Variables ──────────────────────
# Copy this file to .env.local and fill in values for your environment

# Flask API base URL — no trailing slash
# Development: leave empty (Next.js rewrites proxy to localhost:5001)
# Production:  https://api.teachwiseedu.com
NEXT_PUBLIC_API_URL=

# Stripe publishable key — safe to expose, starts with pk_test_ or pk_live_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry DSN — safe to expose in frontend
NEXT_PUBLIC_SENTRY_DSN=

# Server-side Sentry (NOT exposed to browser — no NEXT_PUBLIC_ prefix)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=teachwise-frontend
SENTRY_AUTH_TOKEN=
