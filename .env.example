# ── TeachWise Flask Backend Environment Variables ─────────────────
# Copy this file to .env and fill in values

# ── Core ──────────────────────────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-hex-32
FLASK_ENV=development
FLASK_DEBUG=0
PORT=5001

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/teachwise

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Sessions ──────────────────────────────────────────────────────
# Use 'filesystem' for dev, 'redis' for production
SESSION_TYPE=filesystem

# ── Encryption ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── App URL ───────────────────────────────────────────────────────
APP_URL=http://localhost:5001

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
WALLET_MIN_TOPUP=5
WALLET_MAX_TOPUP=500

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=TeachWise

# ── OpenAI (chatbot) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cloudflare R2 (document storage) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=teachwise-docs
R2_ENDPOINT_URL=
R2_PUBLIC_URL=

# ── Document Verification ────────────────────────────────────────
DOC_MAX_SIZE_MB=5
DOC_RETENTION_DAYS=90

# ── Sentry ────────────────────────────────────────────────────────
SENTRY_DSN=

# ── JWT (microservice auth) ──────────────────────────────────────
JWT_SECRET_KEY=
JWT_EXPIRY=86400

# ── Cache ─────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=900
USER_CACHE_TTL=300

# ── Scheduler ─────────────────────────────────────────────────────
RUN_SCHEDULER=true

# ── App Version ──────────────────────────────────────────────────
APP_VERSION=1.0.0

# ── Microservice URLs (defaults work for Docker Compose) ─────────
# CORE_SERVICE_URL=http://core-service:5000
# SEARCH_SERVICE_URL=http://search-service:5000
# CHAT_SERVICE_URL=http://chat-service:5000
# LEARNING_SERVICE_URL=http://learning-service:5000
# NOTIFICATION_SERVICE_URL=http://notification-service:5000
# SERVICE_CLIENT_TIMEOUT=3
# SERVICE_CLIENT_RETRIES=2
